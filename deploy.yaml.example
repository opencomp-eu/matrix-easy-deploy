matrix:
  domain: matrix.example.com
  server_name: example.com
  admin_username: admin
  # Homeserver software: synapse (default) or tuwunel
  server_implementation: synapse
features:
  registration_enabled: false
  federation_enabled: true
  local_login_enabled: true
  synapse:
    auto_join:
      rooms: []
      # Example when enabling named welcome rooms (recommended: autocreate: false):
      # rooms:
      #   - alias: welcome
      #     name: Welcome
      #     topic: Start here for server info and introductions
      #     message: |
      #       Welcome to Example Chat! We hope you enjoy your time here.
      #   - '#announce:example.com'   # string aliases still work
      autocreate: false
      autocreate_federated: false
      room_preset: public_chat
      # mxid_localpart: system   # required for private_chat / trusted_private_chat
      rooms_for_guests: false
  element:
    enabled: true
    domain: element.example.com
    brand: Example Chat
    default_theme: light
    disable_custom_urls: false
    disable_guests: true
    disable_3pid_login: false
    disable_login_language_selector: false
    branding:
      auth_header_logo_url: https://assets.example.com/element/logo.svg
      welcome_background_url:
        - https://assets.example.com/element/bg-1.jpg
        - https://assets.example.com/element/bg-2.jpg
      auth_footer_links:
        - text: Support
          url: https://example.com/support
    embedded_pages:
      home_url: https://assets.example.com/element/home.html
      welcome_url: https://assets.example.com/element/welcome.html
      login_for_welcome: false
    integrations:
      enabled: true
    room_directory:
      servers:
        - example.com
    labs:
      show_settings: false
      features: {}
    ui_features:
      registration: true
      password_reset: true
      create_public_rooms: true
      create_public_spaces: true
    extra_config: {}
  calls:
    enabled: true
    livekit_domain: livekit.example.com
  sso:
    enabled: false
    providers: []
modules:
  hookshot:
    enabled: true
    domain: hookshot.example.com
  whatsapp_bridge:
    enabled: false
    admin_username: admin
  slack_bridge:
    enabled: false
    admin_username: admin
backup:
  enabled: false
  repository:
    type: local
    path: /var/backups/med-kit
  schedule:
    enabled: false
    calendar: '*-*-* 03:00:00'
    persistent: true
  retention:
    keep_daily: 7
    keep_weekly: 4
    keep_monthly: 6
    keep_yearly: 0
