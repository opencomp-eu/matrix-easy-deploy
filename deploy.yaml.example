matrix:
  domain: matrix.example.com
  server_name: example.com
  admin_username: admin
features:
  registration_enabled: false
  federation_enabled: true
  password_login_enabled: true
  element:
    enabled: true
    domain: element.example.com
  calls:
    enabled: true
    livekit_domain: livekit.example.com
  sso:
    enabled: false
    providers: []
modules:
  hookshot:
    enabled: true
    domain: hookshot.example.com
  whatsapp_bridge:
    enabled: false
    admin_username: admin
  slack_bridge:
    enabled: false
    admin_username: admin
backup:
  enabled: false
  repository:
    type: local
    path: /var/backups/med-kit
  schedule:
    enabled: false
    calendar: '*-*-* 03:00:00'
    persistent: true
  retention:
    keep_daily: 7
    keep_weekly: 4
    keep_monthly: 6
    keep_yearly: 0
